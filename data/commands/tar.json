{
  "schema_version": "commandgraph.command_card.v1",
  "command": "tar",
  "summary": "Create, list, or extract tar archives.",
  "aliases": ["archive", "extract tar", "compress folder"],
  "intents": [
    "compress this folder",
    "create archive",
    "extract tar file",
    "list archive contents"
  ],
  "default_risk": "medium",
  "risk_tags": ["filesystem_write", "archive_extract"],
  "examples": [
    {
      "command": "tar -czf archive.tar.gz folder/",
      "explanation": "Create a compressed archive."
    },
    {
      "command": "tar -tzf archive.tar.gz",
      "explanation": "List archive contents before extracting."
    }
  ],
  "templates": [
    {
      "command": "tar -czf archive.tar.gz {path}",
      "description": "Create a compressed archive from a path."
    },
    {
      "command": "tar -tzf {path}",
      "description": "List archive contents before extracting."
    }
  ]
}
