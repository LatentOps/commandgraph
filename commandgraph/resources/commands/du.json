{
  "schema_version": "commandgraph.command_card.v1",
  "command": "du",
  "summary": "Estimate file and directory disk usage.",
  "aliases": ["disk usage", "folder size", "space"],
  "intents": [
    "show biggest folders",
    "find disk usage",
    "see folder size",
    "free disk space"
  ],
  "default_risk": "low",
  "risk_tags": ["inspection", "filesystem_metadata"],
  "examples": [
    {
      "command": "du -h --max-depth=1 .",
      "explanation": "Show sizes of immediate child directories."
    }
  ],
  "templates": [
    {
      "command": "du -h --max-depth={depth} {path}",
      "description": "Show disk usage by directory depth."
    },
    {
      "command": "du -sh {path}",
      "description": "Show the total size of a path."
    }
  ]
}
